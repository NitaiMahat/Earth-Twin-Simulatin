# Copy this file to .env and fill in your values
# cp .env.example .env

# Gemini API key (required for AI features)
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Server port (optional, defaults to 8000)
PORT=8000

# CORS origins (optional, defaults to "*" for development)
# For production, set to your frontend URL e.g. "https://yourapp.com"
CORS_ORIGINS=*

# Optional persistent provider-cache database.
# You can either set DATABASE_URL directly or use the POSTGRES_* values below.
# For local Docker Postgres, POSTGRES_HOST=localhost works with docker-compose.yml.
DATABASE_URL=postgresql://user:password@host:5432/dbname
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=earth_twin
POSTGRES_USER=earth_twin
POSTGRES_PASSWORD=earth_twin
PROVIDER_CACHE_TABLE_NAME=provider_cache_entries
PROVIDER_CACHE_TTL_SECONDS=3600
PROVIDER_CACHE_CONNECT_TIMEOUT_SECONDS=3

# Public-data provider tuning
PUBLIC_DATA_TIMEOUT_SECONDS=2.5
PUBLIC_DATA_USER_AGENT=EarthTwinBackend/0.1 (planning baseline lookup)

# Supabase auth for protected backend routes like /api/v1/auth/me and /api/v1/my-projects
# Frontend should authenticate with Supabase and send the access token as:
# Authorization: Bearer <supabase_access_token>
# Backend verifies modern Supabase tokens through the project's JWKS endpoint when SUPABASE_URL is set.
# SUPABASE_JWT_SECRET is only needed for legacy HS256 projects.
# Backend also uses the service role key for PDF upload/storage in Supabase Storage.
SUPABASE_JWT_SECRET=
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWT_ISSUER=
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here
SUPABASE_STORAGE_BUCKET=project-reports
SUPABASE_STORAGE_PUBLIC=false
SUPABASE_STORAGE_SIGNED_URL_TTL_SECONDS=3600
